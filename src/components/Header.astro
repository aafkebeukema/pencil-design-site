---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const mainLinks = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Our Services', href: '/services' },
  { label: 'About Us', href: '/about' },
  { label: 'What Clients Say', href: '/what-clients-say' },
  { label: 'Contact', href: '/contact' },
];
---

<header class:list={['site-header', { 'header--transparent': transparent }]}>
  <div class="header-inner">
    <a href="/" class="logo">Pencil Design</a>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      {mainLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  import {
    closeMenuOnMobileLinkClick,
    MOBILE_MENU_MAX_WIDTH,
    resetHeaderMenu,
    setMenuState,
    updateTransparentHeader,
  } from '../lib/header-menu';

  const headers = document.querySelectorAll<HTMLElement>('.site-header');

  headers.forEach((header) => {
    const toggle = header.querySelector<HTMLButtonElement>('.menu-toggle');
    const nav = header.querySelector<HTMLElement>('.site-nav');

    toggle?.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setMenuState(toggle, nav, !isOpen);
    });

    nav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeMenuOnMobileLinkClick(toggle, nav, window.innerWidth);
      });
    });

    if (header.classList.contains('header--transparent')) {
      const update = () => {
        updateTransparentHeader(header, window.scrollY);
      };

      window.addEventListener('scroll', update, { passive: true });
      update();
    }
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > MOBILE_MENU_MAX_WIDTH) {
      headers.forEach((header) => {
        const toggle = header.querySelector<HTMLButtonElement>('.menu-toggle');
        const nav = header.querySelector<HTMLElement>('.site-nav');
        resetHeaderMenu(toggle, nav);
      });
    }
  });
</script>

<style>
  /* ══════════════════════════════════════════
     BASE HEADER
  ══════════════════════════════════════════ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--site-max);
    margin: 0 auto;
    padding: 0 var(--site-gutter);
    height: var(--header-h);
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-black);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.3s;
  }

  /* ── Nav links ── */
  .site-nav {
    display: flex;
    gap: clamp(1rem, 1.8vw, 2rem);
    align-items: center;
  }

  .site-nav > a {
    font-size: 0.78rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-black);
    transition: opacity 0.2s, color 0.3s;
    white-space: nowrap;
  }

  .site-nav > a:hover { opacity: 0.45; }

  /* ── Hamburger ── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-right: -6px;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-black);
    transition: transform 0.25s, opacity 0.25s, background 0.3s;
  }

  .menu-toggle[aria-expanded='true'] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded='true'] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ══════════════════════════════════════════
     TRANSPARENT VARIANT (homepage hero)
  ══════════════════════════════════════════ */
  .header--transparent:not(.header--scrolled) {
    background: transparent;
    border-bottom-color: transparent;
  }

  .header--transparent:not(.header--scrolled) .logo,
  .header--transparent:not(.header--scrolled) .site-nav > a {
    color: var(--color-white);
  }

  .header--transparent:not(.header--scrolled) .menu-toggle span {
    background: var(--color-white);
  }

  /* ══════════════════════════════════════════
     MOBILE NAV
  ══════════════════════════════════════════ */
  @media (max-width: 900px) {
    .menu-toggle { display: flex; }

    .site-nav {
      display: none;
      position: absolute;
      top: var(--header-h);
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: var(--color-white);
      border-bottom: 1px solid var(--color-border);
      align-items: stretch;
      padding-bottom: 0.5rem;
    }

    .site-nav.is-open { display: flex; }

    .site-nav > a {
      padding: 0.9rem var(--site-gutter);
      width: 100%;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-black) !important;
    }

    .site-nav > a:last-child { border-bottom: none; }

    .menu-toggle span { background: var(--color-black) !important; }
  }
</style>
