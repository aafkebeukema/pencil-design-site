---
interface Project {
  title: string;
  description: string;
  bg: string;
}

interface Props {
  category: string;
  headline: string;
  intro: string;
  heroBg: string;
  projects: Project[];
}

const { category, headline, intro, heroBg, projects } = Astro.props;
---

<!-- Hero -->
<section class="cat-hero" style={`background: ${heroBg};`}>
  <!--
    TO ADD A HERO PHOTO:
    Change the style above to:
    style="background-image: url('/images/[photo].jpg'); background-size: cover; background-position: center;"
    Then delete the <div class="cat-hero-bg"> below.
  -->
  <div class="cat-hero-overlay"></div>
  <div class="cat-hero-content">
    <p class="cat-hero-label">{category}</p>
    <h1>{headline}</h1>
  </div>
</section>

<!-- Intro -->
<section class="cat-intro">
  <div class="cat-intro-inner">
    <div class="cat-intro-text">
      <p class="section-label">{category}</p>
      <p>{intro}</p>
    </div>
    <div class="cat-intro-action">
      <a href="/contact" class="btn">Start a project</a>
    </div>
  </div>
</section>

<!-- Project grid -->
<section class="cat-projects">
  <div class="cat-grid">
    {projects.map(project => (
      <div class="project-card" style={`background: ${project.bg};`}>
        <!--
          TO ADD A PHOTO:
          Add to the <div> above:
          style="background-image: url('/images/[photo].jpg'); background-size: cover; background-position: center;"
        -->
        <div class="card-overlay"></div>
        <div class="card-content">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="cat-cta">
  <div class="cat-cta-inner">
    <h2>Have a project in mind?</h2>
    <p>
      Get in touch and we'll arrange a free consultation to talk through what you're looking for.
    </p>
    <a href="/contact" class="btn btn--white">Get in touch</a>
  </div>
</section>

<style>
  /* ============================
     HERO
  ============================ */
  .cat-hero {
    position: relative;
    height: 65vh;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--site-gutter) 4rem;
    background-size: cover;
    background-position: center;
    margin-top: var(--header-h);
  }

  .cat-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.25) 55%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .cat-hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    max-width: var(--site-max);
    width: 100%;
    margin: 0 auto;
  }

  .cat-hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 0.75rem;
  }

  .cat-hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 7vw, 6rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  /* ============================
     INTRO
  ============================ */
  .cat-intro {
    padding: 4rem var(--site-gutter);
    border-bottom: 1px solid var(--color-border);
  }

  .cat-intro-inner {
    max-width: var(--site-max);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    align-items: flex-end;
    flex-wrap: wrap;
  }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 1rem;
  }

  .cat-intro-text {
    max-width: 65ch;
  }

  .cat-intro-text p:not(.section-label) {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.8;
    font-weight: 300;
  }

  /* Button */
  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-black);
    color: var(--color-white);
    border: 1px solid var(--color-black);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn:hover {
    background: transparent;
    color: var(--color-black);
  }

  .btn--white {
    background: var(--color-white);
    color: var(--color-black);
    border-color: var(--color-white);
  }

  .btn--white:hover {
    background: transparent;
    color: var(--color-white);
  }

  /* ============================
     PROJECT GRID
  ============================ */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .project-card {
    position: relative;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    overflow: hidden;
    color: var(--color-white);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 0, 0, 0.1) 60%,
      transparent 100%
    );
    transition: opacity 0.3s;
  }

  .project-card:hover .card-overlay {
    opacity: 0.7;
  }

  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.75rem;
    z-index: 1;
    transform: translateY(0);
    transition: transform 0.3s ease;
  }

  .project-card:hover .card-content {
    transform: translateY(-6px);
  }

  .card-content h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 400;
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }

  .card-content p {
    font-size: 0.85rem;
    opacity: 0.65;
    line-height: 1.55;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      aspect-ratio: 3 / 2;
    }
  }

  /* ============================
     CTA
  ============================ */
  .cat-cta {
    background: var(--color-black);
    padding: clamp(3.5rem, 8vw, 6rem) var(--site-gutter);
    text-align: center;
    color: var(--color-white);
  }

  .cat-cta-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .cat-cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .cat-cta p {
    opacity: 0.6;
    margin-bottom: 2.5rem;
    line-height: 1.7;
    font-size: 1rem;
    font-weight: 300;
  }
</style>
