---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'What materials can you cut?',
    a: 'We cut MDF, plywood, solid timber, acrylic, and most sheet materials. If you\'re unsure whether a material is suitable, just get in touch and we\'ll advise.',
  },
  {
    q: 'Can you work from my own drawings or CAD files?',
    a: 'Yes. We can work from DXF, DWG, PDF, or even a detailed hand sketch. If you need help converting your design into a cuttable file, we can assist with that too.',
  },
  {
    q: 'What\'s the maximum sheet size you can cut?',
    a: 'Our CNC bed handles sheets up to 2440 x 1220mm (standard 8x4). We can discuss larger projects on a case-by-case basis.',
  },
  {
    q: 'Do you offer an edge banding service?',
    a: 'Yes — we offer edge banding in a range of finishes to match your panel material. This gives cut sheet materials a clean, professional finish on exposed edges.',
  },
  {
    q: 'Can I collect my cut parts from your workshop?',
    a: 'Yes, collection is available from our South East London workshop. We also offer delivery for larger orders.',
  },
  {
    q: 'How do I get a quote?',
    a: 'Send us your files or drawings via the contact form and we\'ll come back to you with a price, usually within 24–48 hours.',
  },
  {
    q: 'Do you do one-off pieces or only batch orders?',
    a: 'Both. We\'re equally happy cutting a single prototype or a run of components for a fit-out project.',
  },
  {
    q: 'Can you help with spray finishing cut parts?',
    a: 'Yes — we offer in-house spray finishing in a range of primers, paints, lacquers, and stains. We can finish cut parts before dispatch.',
  },
];
---

<Layout
  title="CNC Cutting | Pencil Design"
  description="CNC cutting and routing services in South East London — MDF, plywood, solid timber, and sheet materials."
>
  <!-- Hero -->
  <section class="cnc-hero">
    <!--
      TO ADD A PHOTO:
      Change style on .cnc-hero-bg to:
      background-image: url('/images/cnc.jpg'); background-size: cover; background-position: center;
    -->
    <div class="cnc-hero-bg"></div>
    <div class="cnc-hero-overlay"></div>
    <div class="cnc-hero-content">
      <p class="hero-label">Workshop services</p>
      <h1>CNC Cutting<br /><em>& Routing</em></h1>
      <p class="hero-body">
        Precision cutting and routing for trade customers and one-off projects alike. MDF, plywood, solid timber, and sheet materials — all cut in our South East London workshop.
      </p>
      <a href="/contact" class="btn btn--white">Get a quote</a>
    </div>
  </section>

  <!-- Services overview -->
  <section class="cnc-services">
    <div class="cnc-services-inner">
      <div class="cnc-service">
        <div class="service-image" style="background: linear-gradient(155deg, #1a1a1a 0%, #333 100%);">
          <!-- Replace with: <img src="/images/cnc-machine.jpg" alt="CNC machine" /> -->
        </div>
        <div class="service-text">
          <p class="step-label">CNC Cutting & Routing</p>
          <h2>Precision cuts, every time.</h2>
          <p>
            We offer CNC cutting and routing for MDF, plywood, and solid timber sheet materials. Whether you need simple panel cuts or complex routed shapes, our machine delivers consistent, accurate results. Suitable for cabinetry components, signage, prototypes, decorative panels, and more.
          </p>
        </div>
      </div>

      <div class="cnc-service cnc-service--reverse">
        <div class="service-image" style="background: linear-gradient(155deg, #2c2010 0%, #4a3818 100%);">
          <!-- Replace with: <img src="/images/edgebanding.jpg" alt="Edge banding" /> -->
        </div>
        <div class="service-text">
          <p class="step-label">Edge Banding</p>
          <h2>Clean edges, professional finish.</h2>
          <p>
            Cut sheet materials can be finished with edge banding in a range of colours and materials to match your panel. This seals exposed edges, improves durability, and gives cabinetry components a furniture-quality finish straight from the workshop.
          </p>
        </div>
      </div>

      <div class="cnc-service">
        <div class="service-image" style="background: linear-gradient(155deg, #1c2020 0%, #2e3030 100%);">
          <!-- Replace with: <img src="/images/panel-saw.jpg" alt="Panel saw" /> -->
        </div>
        <div class="service-text">
          <p class="step-label">General Cutting</p>
          <h2>Panel saw & planer thicknesser.</h2>
          <p>
            Beyond CNC, we offer general sheet material cutting via our panel saw, as well as planing and thicknessing for solid timber. Ideal for trade customers who need accurate, consistent cuts on large volumes of material.
          </p>
        </div>
      </div>

      <div class="cnc-service cnc-service--reverse">
        <div class="service-image" style="background: linear-gradient(155deg, #1e1a2a 0%, #2e2840 100%);">
          <!-- Replace with: <img src="/images/spray.jpg" alt="Spray finishing" /> -->
        </div>
        <div class="service-text">
          <p class="step-label">Spray Finishing</p>
          <h2>Professional finishes in-house.</h2>
          <p>
            Our workshop includes a dedicated spray booth, allowing us to apply primers, paints, lacquers, and stains to cut parts before they leave the workshop. We work in all standard finish types — matt, satin, gloss — and can colour match to your specification.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="faq">
    <div class="faq-inner">
      <div class="faq-header">
        <p class="section-label">Common questions</p>
        <h2>CNC cutting FAQ</h2>
      </div>
      <div class="faq-list">
        {faqs.map((item, i) => (
          <details class="faq-item">
            <summary class="faq-question">
              {item.q}
              <svg class="faq-icon" width="14" height="8" viewBox="0 0 14 8" fill="none">
                <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Need something cut?</h2>
      <p>Send us your files or drawings and we'll come back with a quote, usually within 24–48 hours.</p>
      <a href="/contact" class="btn btn--white">Get a quote</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .cnc-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-h) + 4rem) var(--site-gutter) clamp(2.5rem, 6vw, 5rem);
  }

  .cnc-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #111 0%, #1e1e1e 55%, #0a0a0a 100%);
    background-size: cover;
    background-position: center;
  }

  .cnc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  }

  .cnc-hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    max-width: 700px;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 1.25rem;
  }

  .cnc-hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 7vw, 6rem);
    font-weight: 400;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .cnc-hero-content h1 em {
    font-style: italic;
    font-weight: 300;
  }

  .hero-body {
    font-size: 1.05rem;
    max-width: 50ch;
    opacity: 0.75;
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 2.5rem;
  }

  .btn--white {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-white);
    transition: background 0.2s, color 0.2s;
  }

  .btn--white:hover {
    background: transparent;
    color: var(--color-white);
  }

  /* Services */
  .cnc-services-inner {
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .cnc-service {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .cnc-service--reverse {
    direction: rtl;
  }

  .cnc-service--reverse > * {
    direction: ltr;
  }

  .service-image {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-text {
    padding: 3.5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .step-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 1rem;
  }

  .service-text h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1.12;
    margin-bottom: 1.25rem;
  }

  .service-text p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.8;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .cnc-service,
    .cnc-service--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .service-text {
      padding: 2.5rem var(--site-gutter);
    }

    .cnc-hero {
      min-height: 55vh;
    }
  }

  /* FAQ */
  .faq {
    padding: 6rem var(--site-gutter);
    background: var(--color-off-white);
  }

  .faq-inner {
    max-width: var(--site-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 1rem;
  }

  .faq-header h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 400;
    line-height: 1.15;
    position: sticky;
    top: calc(var(--header-h) + 2rem);
  }

  .faq-list {
    border-top: 1px solid var(--color-border);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 400;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--color-mid);
    transition: transform 0.25s;
  }

  details[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 0 1.5rem;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.8;
    font-weight: 300;
    max-width: 65ch;
  }

  @media (max-width: 768px) {
    .faq-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .faq-header h2 {
      position: static;
    }
  }

  /* CTA */
  .cta {
    background: var(--color-black);
    padding: 7rem var(--site-gutter);
    text-align: center;
    color: var(--color-white);
  }

  .cta-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .cta p {
    opacity: 0.6;
    margin-bottom: 2.75rem;
    line-height: 1.7;
    font-size: 1rem;
    font-weight: 300;
  }
</style>
