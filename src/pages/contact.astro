---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Pencil Design"
  description="Get in touch to discuss your joinery project in South East London."
>
  <div class="contact-wrap">
    <!-- ===========================
         LEFT: heading + details
    ============================ -->
    <div class="contact-left">
      <h1>Contact Us</h1>

      <p class="contact-intro">
        If you would like to discuss your next project with us, or receive a no obligation quote, please contact us via the contact details below:
      </p>

      <div class="contact-details">

        <div class="contact-item">
          <p class="item-label">Email</p>
          <a href="mailto:contact@pencil-design.co.uk">contact@pencil-design.co.uk</a>
        </div>

        <div class="contact-item">
          <p class="item-label">Phone</p>
          <a href="tel:+442080164163">+44 20 8016 4163</a>
        </div>

        <div class="contact-item">
          <p class="item-label">Address</p>
          <p>South East London</p>
        </div>

      </div>

      <div class="social-row">
        <a href="mailto:contact@pencil-design.co.uk" aria-label="Email">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>
        <a href="tel:+442080164163" aria-label="Phone">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.52 19.52 0 0 1-6-6A19.8 19.8 0 0 1 2.08 4.18 2 2 0 0 1 4.06 2h3a2 2 0 0 1 2 1.72l.45 3.09a2 2 0 0 1-.57 1.72L7.1 10.37a16 16 0 0 0 6.53 6.53l1.84-1.84a2 2 0 0 1 1.72-.57l3.09.45A2 2 0 0 1 22 16.92z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .contact-wrap {
    min-height: calc(100svh - var(--header-h));
    padding-top: var(--header-h);
  }

  /* ===========================
     LEFT COLUMN
  ============================ */
  .contact-left {
    max-width: var(--site-max);
    margin: 0 auto;
    padding: 4rem var(--content-rail) 5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .contact-left h1 {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(2rem, 7vw, 6rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: 1.75rem;
  }

  .contact-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-black);
    font-weight: 300;
    max-width: 38ch;
    margin-bottom: 2.5rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.75rem;
    width: 100%;
  }

  .item-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: 0.2rem;
    letter-spacing: 0;
  }

  .contact-item a,
  .contact-item p:not(.item-label) {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-black);
    text-decoration: none;
    line-height: 1.6;
  }

  .contact-item a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-item a:hover {
    opacity: 0.55;
  }

  /* Social icons */
  .social-row {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .social-row a {
    color: var(--color-black);
    display: flex;
    align-items: center;
    padding: 8px;
    margin: -8px;
    transition: opacity 0.2s;
  }

  .social-row a:hover {
    opacity: 0.45;
  }

  /* ===========================
     RESPONSIVE
  ============================ */
  @media (max-width: 768px) {
    .contact-left {
      padding-top: 3rem;
    }
  }

  @media (max-width: 480px) {
    .contact-left {
      padding-bottom: 4rem;
    }
  }
</style>
