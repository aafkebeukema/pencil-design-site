---
import Layout from '../layouts/Layout.astro';

const serviceImageSets = {
  design: [
    { src: '/pencil-design-site/images/service-circle-01.png', alt: 'Joinery design concept illustration' },
    { src: '/pencil-design-site/images/service-circle-02.jpg', alt: 'Measured joinery design drawing and planning work' },
    { src: '/pencil-design-site/images/service-circle-03.jpg', alt: 'Bespoke joinery design materials and samples' },
    { src: '/pencil-design-site/images/service-circle-04.jpg', alt: 'Joinery design detailing for a fitted project' },
    { src: '/pencil-design-site/images/service-circle-05.jpg', alt: 'Design development for bespoke fitted furniture' },
  ],
  build: [
    { src: '/pencil-design-site/images/service-build-01.jpg', alt: 'Joinery work in progress in the workshop', size: '118%', position: 'center' },
    { src: '/pencil-design-site/images/service-build-02.jpg', alt: 'Bespoke furniture being built by hand', size: '118%', position: 'center' },
    { src: '/pencil-design-site/images/service-build-03.jpg', alt: 'Custom joinery assembly in the workshop', size: '118%', position: 'center' },
    { src: '/pencil-design-site/images/service-build-04.jpg', alt: 'Joinery craftsmanship and cabinet construction', size: '118%', position: 'center' },
    { src: '/pencil-design-site/images/service-build-05.jpg', alt: 'Workshop build stage for fitted furniture', size: '118%', position: 'center' },
  ],
  finish: [
    { src: '/pencil-design-site/images/service-finish-01.jpg', alt: 'Finished bespoke joinery detail and paintwork' },
    { src: '/pencil-design-site/images/service-finish-02.jpg', alt: 'Completed fitted joinery with final finish applied' },
    { src: '/pencil-design-site/images/service-finish-03.jpg', alt: 'Completed cabinetry with finished hardware details' },
    { src: '/pencil-design-site/images/service-finish-04.jpg', alt: 'Finished bespoke timber detail in a completed project' },
    { src: '/pencil-design-site/images/service-finish-05.jpg', alt: 'Final joinery finish and installation detail' },
  ],
};

const services = [
  {
    label: 'Design it',
    body: 'Every project begins with a site visit and a thoughtful conversation about what you need. We measure up, discuss materials and finishes, and prepare detailed drawings and a quote before anything is built. There is no commitment until you\'re happy with the plan.',
    images: serviceImageSets.design,
  },
  {
    label: 'Build it',
    body: 'Each project is built to suit your space, combining workshop joinery with skilled on-site craftsmanship where needed. Our professional, adaptable team works with care and respect throughout the process, with attention to the build itself, the surrounding environment, and the people around it.',
    images: serviceImageSets.build,
  },
  {
    label: 'Finish it',
    body: 'We offer a complete painting and finishing service in-house — hand-painted cabinetry, spray finishes, oiled and lacquered solid wood, and a full range of hardware. We can also supply pieces unfinished if you\'re working with your own decorator.',
    images: serviceImageSets.finish,
  },
];
---

<Layout
  title="Our Services | Pencil Design"
  description="Bespoke joinery services in South East London — design, manufacture, finishing, and installation."
>

  <!-- ===========================
       PAGE HEADER — large, centred, bold
  ============================ -->
  <div class="page-header">
    <h1>Our Services</h1>
    <p class="page-tagline">From concept to completion, every stage is led by design and built around your space.</p>
  </div>

  <!-- ===========================
       THREE-COLUMN SERVICES
  ============================ -->
  <section class="services-section">
    <div class="services-cols">
      {services.map(service => (
        <div class="service-col">
          <div class="service-body">
            <p class="service-label">{service.label}</p>
            <p class="service-desc">{service.body}</p>
          </div>

          <!--
            TO ADD A PHOTO:
            Replace background with:
              style="background-image: url('/images/design.jpg'); background-size: cover; background-position: center;"
          -->
          <div class="service-circles">
            {service.images.map((image) => (
              <div class="service-img-wrap service-img-wrap--circle">
                <img
                  class="service-img"
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  decoding="async"
                  style={`object-position: ${image.position ?? 'center'}; --image-scale: ${image.size ? Number.parseFloat(image.size) / 100 : 1};`}
                />
              </div>
            ))}
          </div>

        </div>
      ))}
    </div>
  </section>

  <!-- ===========================
       PROCESS STEPS
  ============================ -->
  <section class="process">
    <div class="process-inner">
      <p class="section-label">How a project works</p>
      <div class="process-steps">
        <div class="step">
          <p class="step-num">01</p>
          <h3>Get in touch</h3>
          <p>Contact us and we'll get back to arrange a face-to-face meeting at a time that suits you.</p>
        </div>
        <div class="step">
          <p class="step-num">02</p>
          <h3>Site visit &amp; design</h3>
          <p>We'll come and see you, talk through the design, take measurements, and provide a free quote with no obligation or pressure.</p>
        </div>
        <div class="step">
          <p class="step-num">03</p>
          <h3>Approve &amp; schedule</h3>
          <p>Once you're happy with the design and quote, we agree a start date and begin making.</p>
        </div>
        <div class="step">
          <p class="step-num">04</p>
          <h3>Build &amp; install</h3>
          <p>Depending on the project, we carry out a mix of workshop making and on-site work, then complete the installation with care and attention to detail.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===========================
       CTA
  ============================ -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Ready to get started?</h2>
      <p>Get in touch and we'll arrange a free, no-obligation consultation to discuss your project.</p>
      <a href="/pencil-design-site/contact" class="btn">Get in touch</a>
    </div>
  </section>

</Layout>

<style>
  /* ===========================
     PAGE HEADER
  ============================ */
  .page-header {
    padding: calc(var(--header-h) + 3rem) var(--site-gutter) 3rem;
    max-width: var(--site-max);
    margin: 0 auto;
    text-align: left;
  }

  .page-header h1 {
    /* Very large, heavy — nearly spans the full viewport width */
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(2rem, 9vw, 7rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: 1.75rem;
  }

  .page-tagline {
    /* Big statement — not a caption */
    font-size: clamp(1.1rem, 2vw, 1.7rem);
    color: var(--color-black);
    font-weight: 400;
    width: auto;
    max-width: 34ch;
    margin: 0;
    line-height: 1.3;
    white-space: normal;
  }

  /* ===========================
     SERVICES COLUMNS
  ============================ */
  .services-section {
    padding-top: 1rem;
  }

  .services-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 1200px;
    margin: 0 auto;
  }

  .service-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    padding: 2.5rem 1.75rem 3.5rem;
    text-align: center;
  }

  /* ---- Images ---- */
  .service-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(var(--image-scale, 1));
    transform-origin: center;
  }

  .service-img-wrap--circle {
    width: min(85%, 270px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-off-white);
  }

  .service-circles {
    display: grid;
    gap: 1.25rem;
    width: 100%;
    justify-items: center;
    margin-top: auto;
    padding-top: 2.5rem;
  }

  /* ---- Text below image ---- */
  .service-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 34ch;
  }

  /* "DESIGN IT", "MAKE IT" etc. — the main title, prominent */
  .service-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-black);
    margin-bottom: 1rem;
  }

  .service-desc {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.85;
    font-weight: 300;
  }

  /* Tablet: 2 columns */
  @media (max-width: 640px) {
    .services-cols {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: 1 column */
  @media (max-width: 420px) {
    .services-cols {
      grid-template-columns: 1fr;
    }

    .service-col {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .service-col:last-child {
      border-bottom: none;
    }

    .service-img-wrap--circle {
      width: min(60%, 220px);
    }
  }

  /* ===========================
     PROCESS STEPS
  ============================ */
  .process {
    padding: 5.5rem var(--site-gutter);
    background: var(--color-off-white);
  }

  .process-inner {
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 2.5rem;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
  }

  .step {
    padding-right: 2.5rem;
  }

  .step-num {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-mid);
    margin-bottom: 0.75rem;
  }

  .step h3 {
    font-family: var(--font-heading);
    font-size: 1.45rem;
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .step p {
    font-size: 0.875rem;
    color: var(--color-mid);
    line-height: 1.7;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .process-steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .step {
      padding-right: 0;
    }
  }

  @media (max-width: 520px) {
    .process-steps {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .step {
      padding-right: 0;
    }
  }

  /* ===========================
     CTA
  ============================ */
  .cta {
    background: var(--color-black);
    padding: 7rem var(--site-gutter);
    text-align: center;
    color: var(--color-white);
  }

  .cta-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .cta p {
    opacity: 0.6;
    margin-bottom: 2.75rem;
    line-height: 1.7;
    font-size: 1rem;
    font-weight: 300;
  }

  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-white);
    transition: background 0.2s, color 0.2s;
  }

  .btn:hover {
    background: transparent;
    color: var(--color-white);
  }
</style>
