  project.src = withBase(project.src);
});
---

<Layout
  title="Bespoke Construction & Joinery Projects in South East London | Pencil Design"
  description="Bespoke construction and joinery projects across South East London — kitchens, bathrooms, wardrobes, stairs, and built-in shelving, designed and built by Pencil Design."
>
  <div class="projects-main">
    <div class="page-intro">
      <h1>Our Work</h1>
      <h2 class="page-subtitle">Bespoke construction and joinery across South East London</h2>
    </div>

    <section class="projects-grid-section">
      <div class="projects-grid">
        {projects.map((project, index) => (
          <div class="project-item">
            <div class="project-image">
              <img
                src={project.src}
                alt={project.alt}
                loading={index < 6 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            <p class="caption-title">{project.title}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="projects-cta">
      <div class="projects-cta-inner">
        <h2>Have a project in mind?</h2>
        <p>Get in touch and we'll arrange a free consultation to talk through what you're looking for.</p>
        <a href={withBase('/contact')} class="btn">Get in touch</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .projects-main {
    background: var(--color-white);
  }

  /* ── Page intro ── */
  .page-intro {
    padding: calc(var(--header-h) + 3.5rem) var(--site-gutter) 2.5rem;
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .page-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 0.75rem;
  }

  .page-intro h1 {
    font-family: var(--font-body);
    font-size: clamp(2rem, 9vw, 7rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  .page-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-top: 1rem;
    font-weight: 400;
  }

  .page-intro-copy {
    max-width: 42rem;
    margin-top: 1.25rem;
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.75;
    color: #555;
  }

  /* ── Grid ── */
  .projects-grid-section {
    padding: 0 var(--site-gutter) 5rem;
    max-width: var(--site-max);
    margin: 0 auto;
  }

  /*
   * row-gap: 0 so the grid itself adds no vertical space between rows.
   * The caption's padding-bottom (20px) becomes the sole gap between
   * the caption text and the top of the next image row — matching the
   * column-gap (20px) exactly.
   */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 48px;
    row-gap: 0;
  }

  .project-item {
    display: flex;
    flex-direction: column;
  }

  .project-image {
    aspect-ratio: 1 / 1;
    width: 100%;
    overflow: hidden;
    background: var(--color-off-white);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .caption-title {
    padding-top: 10px;
    padding-bottom: 20px;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-black);
    font-weight: 500;
  }

  /* Last row: no padding-bottom after final captions */
  .project-item:nth-last-child(-n+3) .caption-title {
    padding-bottom: 0;
  }

  /* ── CTA ── */
  .projects-cta {
    background: var(--color-off-white);
    padding: 6rem var(--site-gutter);
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .projects-cta-inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .projects-cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .projects-cta p {
    color: var(--color-mid);
    margin-bottom: 2.25rem;
    line-height: 1.7;
    font-weight: 300;
  }

  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-black);
    color: var(--color-white);
    border: 1px solid var(--color-black);
    transition: background 0.2s, color 0.2s;
  }

  .btn:hover {
    background: transparent;
    color: var(--color-black);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 32px;
    }
    .caption-title { padding-bottom: 14px; }
    .project-item:nth-last-child(-n+2) .caption-title { padding-bottom: 0; }
  }

  @media (max-width: 520px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .caption-title { padding-bottom: 12px; }
    .project-item:last-child .caption-title { padding-bottom: 0; }
  }
</style>
