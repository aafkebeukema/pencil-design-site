---

<Layout
  title="Projects | Pencil Design"
  description="Bespoke joinery projects across South East London — kitchens, wardrobes, alcove shelving, and fitted furniture."
>
  <Header />

  <main class="projects-main">
    <div class="page-intro">
      <p class="page-label">Our work</p>
      <h1>Projects</h1>
    </div>

    <section class="projects-grid-section">
      <div class="projects-grid">
        {projects.map(project => (
          <div class="project-item">
            <div
              class="project-image"
              style={`background-image: ${project.bg};`}
            ></div>
            <p class="caption-title">{project.title}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="projects-cta">
      <div class="projects-cta-inner">
        <h2>Have a project in mind?</h2>
        <p>Get in touch and we'll arrange a free consultation to talk through what you're looking for.</p>
        <a href="/pencil-design-site/contact" class="btn">Get in touch</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .projects-main {
    background: var(--color-white);
  }

  /* ── Page intro ── */
  .page-intro {
    padding: calc(var(--header-h) + 3.5rem) var(--site-gutter) 2.5rem;
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .page-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 0.75rem;
  }

  .page-intro h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1.05;
  }

  /* ── Grid ── */
  .projects-grid-section {
    padding: 0 var(--site-gutter) 5rem;
    max-width: var(--site-max);
    margin: 0 auto;
  }

  /*
   * row-gap: 0 so the grid itself adds no vertical space between rows.
   * The caption's padding-bottom (20px) becomes the sole gap between
   * the caption text and the top of the next image row — matching the
   * column-gap (20px) exactly.
   */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 48px;
    row-gap: 0;
  }

  .project-item {
    display: flex;
    flex-direction: column;
  }

  .project-image {
    aspect-ratio: 1 / 1;
    background-size: cover;
    background-position: center;
    width: 100%;
  }

  .caption-title {
    padding-top: 10px;
    padding-bottom: 20px;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-black);
    font-weight: 500;
  }

  /* Last row: no padding-bottom after final captions */
  .project-item:nth-last-child(-n+3) .caption-title {
    padding-bottom: 0;
  }

  /* ── CTA ── */
  .projects-cta {
    background: var(--color-off-white);
    padding: 6rem var(--site-gutter);
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .projects-cta-inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .projects-cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .projects-cta p {
    color: var(--color-mid);
    margin-bottom: 2.25rem;
    line-height: 1.7;
    font-weight: 300;
  }

  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-black);
    color: var(--color-white);
    border: 1px solid var(--color-black);
    transition: background 0.2s, color 0.2s;
  }

  .btn:hover {
    background: transparent;
    color: var(--color-black);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 32px;
    }
    .caption-title { padding-bottom: 14px; }
    .project-item:nth-last-child(-n+2) .caption-title { padding-bottom: 0; }
  }

  @media (max-width: 520px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .caption-title { padding-bottom: 12px; }
    .project-item:last-child .caption-title { padding-bottom: 0; }
  }
</style>
