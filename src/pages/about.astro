---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About | Pencil Design"
  description="A South East London joinery workshop making bespoke fitted furniture for homes and businesses."
>

  <!-- ===========================
       PAGE HEADER
  ============================ -->
  <div class="page-header">
    <h1>About Us</h1>
  </div>

  <!-- ===========================
       INTRO — full-width text
  ============================ -->
  <section class="intro">
    <div class="intro-inner">
      <p>
        Pencil Design is a design-led construction and renovation company based in South East London, working with homeowners and businesses across the South East to create bespoke interiors, fitted furniture, and carefully made spaces that are built to last.
      </p>
      <p>
        With a strong foundation in architecture, design, and construction, we take on projects ranging from home renovations and new-build work to kitchens, bathrooms, wardrobes, cabinetry, built-in storage, and bespoke joinery. Our approach combines thoughtful design with practical know-how, so every project is tailored to the space, realistic to build, and delivered with care.
      </p>
    </div>
  </section>

  <!-- ===========================
       CTA
  ============================ -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Ready to start a project?</h2>
      <p>Get in touch and we'll arrange a free, no-obligation consultation to discuss what you have in mind.</p>
      <a href="/pencil-design-site/contact" class="btn">Get in touch</a>
    </div>
  </section>

</Layout>

<style>
  /* ===========================
     PAGE HEADER
  ============================ */
  .page-header {
    padding: calc(var(--header-h) + 3rem) var(--site-gutter) 3rem;
    max-width: var(--site-max);
    margin: 0 auto;
    text-align: left;
  }

  .page-header h1 {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(2rem, 9vw, 7rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  /* ===========================
     INTRO
  ============================ */
  .intro {
    padding: 3rem var(--site-gutter) 5rem;
    border-top: 1px solid var(--color-border);
  }

  .intro-inner {
    max-width: var(--site-max);
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }

  .intro-inner p {
    font-size: clamp(1rem, 1.3vw, 1.05rem);
    line-height: 1.85;
    color: var(--color-black);
    font-weight: 300;
  }

  /* ===========================
     CTA
  ============================ */
  .cta {
    background: var(--color-black);
    padding: 7rem var(--site-gutter);
    text-align: center;
    color: var(--color-white);
  }

  .cta-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .cta p {
    opacity: 0.6;
    margin-bottom: 2.75rem;
    line-height: 1.7;
    font-size: 1rem;
    font-weight: 300;
  }

  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-white);
    transition: background 0.2s, color 0.2s;
  }

  .btn:hover {
    background: transparent;
    color: var(--color-white);
  }
</style>
