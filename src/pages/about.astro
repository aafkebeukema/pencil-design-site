---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About | Pencil Design"
  description="A South East London joinery workshop making bespoke fitted furniture for homes and businesses."
>

  <!-- ===========================
       PAGE HEADER
  ============================ -->
  <div class="page-header">
    <h1>About Us</h1>
  </div>

  <!-- ===========================
       INTRO — full-width text
  ============================ -->
  <section class="intro">
    <div class="intro-inner">
      <p>
        Pencil Design is a South East London workshop making bespoke fitted furniture for homes and businesses. We work with homeowners, architects, interior designers, and commercial clients who want furniture built properly — designed for the space, made to last. We've been doing this for a while now, so you could say we know a thing or two about crafting amazing cabinets and joinery. We work across a variety of sectors — from homeowners who want a dream kitchen to architects with grand designs, so no matter your style or project, we're here to help bring your vision to life. Simply put, we pour our hearts into every project, making sure it's top-notch and our customers are thrilled with the end result.
      </p>
    </div>
  </section>

  <!-- ===========================
       TEAM
  ============================ -->
  <section class="team">
    <div class="team-inner">
      <div class="team-grid">

        <div class="team-member">
          <!--
            TO ADD A PHOTO:
            Replace the <div class="member-img"> below with:
            <img src="/images/sam-portrait.jpg" alt="Sam" />
          -->
          <div class="member-img" style="background: linear-gradient(155deg, #2a2010 0%, #4a3818 100%);"></div>
          <h2>Sam — Founder &amp; Lead Joiner</h2>
          <p>
            Sam has been working in joinery and furniture making for over a decade, starting out on a design and craft course before spending several years working for other workshops across South London. He set up Pencil Design to do things his own way — with more attention to the details, and more honest communication with clients from start to finish.
          </p>
          <p>
            When he's not in the workshop, he's most likely found hunting for interesting secondhand tools, or arguing about the best way to finish solid oak.
          </p>
        </div>

        <!--
          To add more team members, copy the block above and paste it here.
        -->

      </div>
    </div>
  </section>

  <!-- ===========================
       CTA
  ============================ -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Ready to start a project?</h2>
      <p>Get in touch and we'll arrange a free, no-obligation consultation to discuss what you have in mind.</p>
      <a href="/pencil-design-site/contact" class="btn">Get in touch</a>
    </div>
  </section>

</Layout>

<style>
  /* ===========================
     PAGE HEADER
  ============================ */
  .page-header {
    padding: calc(var(--header-h) + 3rem) var(--site-gutter) 3rem;
    text-align: center;
  }

  .page-header h1 {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(2rem, 9vw, 7rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  /* ===========================
     INTRO
  ============================ */
  .intro {
    padding: 3rem var(--site-gutter) 5rem;
    border-top: 1px solid var(--color-border);
  }

  .intro-inner {
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .intro-inner p {
    font-size: clamp(1rem, 1.3vw, 1.05rem);
    line-height: 1.85;
    color: var(--color-black);
    font-weight: 300;
  }

  /* ===========================
     TEAM
  ============================ */
  .team {
    padding: 5rem var(--site-gutter) 6rem;
    border-top: 1px solid var(--color-border);
  }

  .team-inner {
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4rem;
  }

  .member-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    margin-bottom: 1.5rem;
    background-size: cover;
    background-position: center;
  }

  /* Replace with <img> when you have photos */
  .team-member img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    margin-bottom: 1.5rem;
  }

  .team-member h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 400;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .team-member p {
    font-size: 0.925rem;
    color: #555;
    line-height: 1.85;
    font-weight: 300;
    margin-bottom: 0.9rem;
  }

  .team-member p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* ===========================
     CTA
  ============================ */
  .cta {
    background: var(--color-black);
    padding: 7rem var(--site-gutter);
    text-align: center;
    color: var(--color-white);
  }

  .cta-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .cta p {
    opacity: 0.6;
    margin-bottom: 2.75rem;
    line-height: 1.7;
    font-size: 1rem;
    font-weight: 300;
  }

  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    background: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-white);
    transition: background 0.2s, color 0.2s;
  }

  .btn:hover {
    background: transparent;
    color: var(--color-white);
  }
</style>
