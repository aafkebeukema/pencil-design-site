---
import Layout from '../layouts/Layout.astro';
import CategoryPage from '../components/CategoryPage.astro';

const projects = [
  {
    title: 'East Dulwich Wine Bar',
    description: 'Bar front, back bar shelving, and bespoke wine storage for a 35-cover wine bar.',
    bg: 'linear-gradient(155deg, #2a1a0a 0%, #4a3015 100%)',
  },
  {
    title: 'Peckham Coffee Roasters',
    description: 'Counter, retail shelving, and bench seating in reclaimed oak and powder-coated steel.',
    bg: 'linear-gradient(155deg, #1a1a1a 0%, #383838 100%)',
  },
  {
    title: 'Bermondsey Restaurant',
    description: 'Banquette seating, host stand, and full bar fit-out for a 60-cover neighbourhood restaurant.',
    bg: 'linear-gradient(155deg, #2c1e10 0%, #4a3220 100%)',
  },
  {
    title: 'Herne Hill Café',
    description: 'Service counter, shelving, and built-in bench seating throughout the ground floor.',
    bg: 'linear-gradient(155deg, #1c2c20 0%, #2e4832 100%)',
  },
  {
    title: 'Borough Cocktail Bar',
    description: 'Backlit bar shelving, bespoke seating booths, and a marble-topped bar front.',
    bg: 'linear-gradient(155deg, #1e1a2c 0%, #302840 100%)',
  },
  {
    title: 'Forest Hill Pub Refurb',
    description: 'Full interior joinery refurbishment — bar front, booth seating, and new shelving throughout.',
    bg: 'linear-gradient(155deg, #2c2010 0%, #4a3820 100%)',
  },
];
---

<Layout
  title="Hospitality Projects | Pencil Design"
  description="Bespoke hospitality joinery in London — bars, restaurants, cafés, and commercial interiors."
>
  <CategoryPage
    category="Hospitality"
    headline="Spaces that work as hard as you do."
    intro="We design and build joinery for restaurants, bars, cafés, and hospitality spaces across London. Pieces that look great on day one and hold up to years of daily use — because in a hospitality environment, durability and beauty need to go hand in hand."
    heroBg="linear-gradient(160deg, #1a1005 0%, #2a1c08 55%, #120d03 100%)"
    projects={projects}
  />
</Layout>
