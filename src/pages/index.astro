---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    title: 'Hospitality',
    href: '/pencil-design-site/hospitality',
    tagline: 'CUSTOM BUILT.',
    subtitle: 'Hospitality spaces that look as good as they work.',
    align: 'right',
    // TO ADD A PHOTO: replace bg with → background-image: url('/images/hospitality.jpg'); background-size: cover; background-position: center;
    bg: 'linear-gradient(160deg, #1a1005 0%, #2e1c08 55%, #120d03 100%)',
  },
  {
    title: 'Residential',
    href: '/pencil-design-site/residential',
    tagline: 'TAILOR-MADE.',
    subtitle: 'Residential joinery that will have you planning your next home improvements.',
    align: 'left',
    bg: 'linear-gradient(160deg, #3a2810 0%, #5a4020 55%, #2c1e08 100%)',
  },
  {
    title: 'Retail',
    href: '/pencil-design-site/retail',
    tagline: 'BESPOKE.',
    subtitle: 'Retail projects that are the envy of the high street.',
    align: 'right',
    bg: 'linear-gradient(160deg, #1a1520 0%, #2a2035 55%, #12101a 100%)',
  },
  {
    title: 'Workspace',
    href: '/pencil-design-site/workspace',
    tagline: 'UNIQUE.',
    subtitle: 'Workspaces that inspire and motivate.',
    align: 'left',
    bg: 'linear-gradient(160deg, #1a1a1a 0%, #2e2e2e 55%, #111 100%)',
  },
];
---

<Layout title="Sam's Joinery | Bespoke Joinery in South East London" transparentHeader={true}>

  <!-- =====================
       HERO
  ====================== -->
  <section class="hero">
    <!--
      TO ADD YOUR HERO PHOTO:
      1. Save your image to: public/images/hero.jpg
      2. Remove the <div class="hero-bg"> below
      3. Replace it with: <div class="hero-bg" style="background-image: url('/images/hero.jpg')"></div>
    -->
    <div class="hero-bg"></div>

    <div class="hero-content">
      <h1>Not just another<br />joinery workshop.</h1>
      <p class="hero-body">
        We love the unusual, the complicated, and the unexpected. With years of experience in carpentry, joinery, and cabinet making across South East London, we design, build, and install bespoke fitted furniture for residential and commercial spaces — made to measure, and made to last.
      </p>
      <div class="hero-actions">
        <a href="/pencil-design-site/services" class="btn-pill">Our Services</a>
        <a href="/pencil-design-site/projects" class="btn-pill btn-pill--ghost">View projects</a>
      </div>
    </div>
  </section>

  <!-- =====================
       PROJECT CATEGORIES
  ====================== -->
  <section class="categories">
    {categories.map(cat => (
      <a
        href={cat.href}
        class={`cat-section cat-section--${cat.align}`}
      >
        <!--
          TO ADD A PHOTO:
          On the <a> tag above, add after the class:
            style="--cat-bg: url('/images/[photo].jpg')"
          Then change .cat-bg in CSS to use var(--cat-bg) as background-image.
          Or simply change the bg value in the categories array above.
        -->
        <div class="cat-bg" style={`background: ${cat.bg};`}></div>
        <div class="cat-body">
          <h2 class="cat-tagline">{cat.tagline}</h2>
          <p class="cat-subtitle">{cat.subtitle}</p>
          <span class="cat-btn">{cat.title} Projects</span>
        </div>
      </a>
    ))}
  </section>

  <!-- =====================
       ABOUT TEASER
  ====================== -->
  <section class="about">
    <div class="about-inner">
      <div class="about-text">
        <p class="section-label">About us</p>
        <h2>Craft and care in every detail.</h2>
        <p>
          We're a small joinery workshop based in South East London. We work closely with homeowners, architects, and designers to create fitted furniture that's genuinely built to last — no flat-pack, no off-the-shelf. Every piece is designed and made specifically for your space.
        </p>
        <p>
          With years of experience across residential and commercial projects, we take pride in getting the details right: the joints, the finishes, the fit.
        </p>
        <a href="/pencil-design-site/about" class="btn btn--dark">Learn more about us</a>
      </div>

      <div class="about-image">
        <!--
          TO ADD YOUR PHOTO:
          Replace the <div class="about-placeholder"> below with:
          <img src="/images/about.jpg" alt="The workshop" />
        -->
        <div class="about-placeholder"></div>
      </div>
    </div>
  </section>

  <!-- =====================
       SERVICES STRIP
  ====================== -->
  <section class="services">
    <div class="services-inner">
      <p class="section-label">What we offer</p>
      <div class="services-grid">
        <div class="service">
          <h4>Design consultation</h4>
          <p>We work through every detail with you before a single piece of wood is cut.</p>
        </div>
        <div class="service">
          <h4>Bespoke manufacture</h4>
          <p>Everything is made from scratch in our South East London workshop — built to fit.</p>
        </div>
        <div class="service">
          <h4>Supply &amp; install</h4>
          <p>Our team handles delivery and fitting with minimal disruption to your home or business.</p>
        </div>
      </div>
      <div class="services-cta">
        <a href="/pencil-design-site/services" class="btn btn--dark">See all services</a>
      </div>
    </div>
  </section>

  <!-- =====================
       CONTACT CTA
  ====================== -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Ready to start a project?</h2>
      <p>Get in touch and we'll arrange a free consultation to talk through what you have in mind.</p>
      <a href="/pencil-design-site/contact" class="btn btn--white">Get in touch</a>
    </div>
  </section>

</Layout>

<style>
  /* ====================================
     SHARED
  ==================================== */
  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 1.25rem;
  }

  /* ====================================
     BUTTONS
  ==================================== */
  .btn {
    display: inline-block;
    padding: 0.9rem 1.9rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 500;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    border: 1px solid transparent;
    cursor: pointer;
  }

  .btn--dark {
    background: var(--color-black);
    color: var(--color-white);
    border-color: var(--color-black);
    margin-top: 2.25rem;
  }

  .btn--dark:hover {
    background: transparent;
    color: var(--color-black);
  }

  /* ====================================
     HERO
  ==================================== */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--site-gutter) 5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    /*
      Placeholder gradient.
      TO ADD YOUR HERO PHOTO:
        background-image: url('/images/hero.jpg');
        background-size: cover;
        background-position: center;
    */
    background: linear-gradient(160deg, #1c1409 0%, #2e2010 55%, #180e04 100%);
    background-size: cover;
    background-position: center;
  }

  /* Subtle overlay — keep even with a real photo so text stays legible */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.2) 60%,
      rgba(0, 0, 0, 0.05) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    max-width: 1000px;
  }

  .hero-content h1 {
    /* Large, light — matching the reference's airy, confident style */
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 9vw, 8.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
  }

  .hero-body {
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    max-width: 68ch;
    opacity: 0.85;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Pill buttons — matching the rounded outline style in the reference */
  .btn-pill {
    display: inline-block;
    padding: 0.8rem 1.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    font-weight: 400;
    text-decoration: none;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.75);
    color: var(--color-white);
    background: transparent;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-pill:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--color-white);
  }

  .btn-pill--ghost {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .btn-pill--ghost:hover {
    border-color: rgba(255, 255, 255, 0.75);
  }

  /* ====================================
     CATEGORIES — full-height stacked sections
  ==================================== */
  .categories {
    /* stacked, no gap */
  }

  .cat-section {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 75vh;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-white);
  }

  /* Background image/gradient */
  .cat-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.7s ease;
  }

  .cat-section:hover .cat-bg {
    transform: scale(1.04);
  }

  /* Subtle dark overlay — light enough to let the photo breathe */
  .cat-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.32);
    transition: background 0.4s;
  }

  .cat-section:hover .cat-bg::after {
    background: rgba(0, 0, 0, 0.22);
  }

  /* Content block */
  .cat-body {
    position: relative;
    z-index: 1;
    padding: 0 var(--site-gutter) 4.5rem;
    width: 100%;
  }

  /* Right-aligned variant */
  .cat-section--right .cat-body {
    text-align: right;
  }

  /* The big bold tagline */
  .cat-tagline {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(2.5rem, 13vw, 12rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  /* Short subtitle */
  .cat-subtitle {
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    opacity: 0.8;
    font-weight: 300;
    margin-bottom: 1.75rem;
    max-width: 48ch;
    line-height: 1.55;
  }

  .cat-section--right .cat-subtitle {
    margin-left: auto;
  }

  /* Small pill button */
  .cat-btn {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.65);
    border-radius: 999px;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    font-weight: 400;
    color: var(--color-white);
    transition: background 0.2s, border-color 0.2s;
  }

  .cat-section:hover .cat-btn {
    background: rgba(255, 255, 255, 0.14);
    border-color: var(--color-white);
  }

  @media (max-width: 600px) {
    .cat-section {
      min-height: 55vh;
    }

    .cat-tagline {
      font-size: clamp(2.25rem, 16vw, 5rem);
    }

    /* Stack all left on mobile */
    .cat-section--right .cat-body {
      text-align: left;
    }

    .cat-section--right .cat-subtitle {
      margin-left: 0;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .btn-pill {
      width: 100%;
      text-align: center;
    }
  }

  /* ====================================
     ABOUT
  ==================================== */
  .about {
    padding: 7rem var(--site-gutter);
    background: var(--color-off-white);
  }

  .about-inner {
    max-width: var(--site-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-text h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 4vw, 3.75rem);
    font-weight: 400;
    line-height: 1.12;
    margin-bottom: 1.75rem;
  }

  .about-text p {
    color: #555;
    line-height: 1.8;
    font-size: 1rem;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  .about-text p:last-of-type {
    margin-bottom: 0;
  }

  .about-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    /* Placeholder — swap for: <img src="/images/about.jpg" alt="..." /> */
    background: linear-gradient(155deg, #3a2e1e 0%, #5c4530 50%, #2e2415 100%);
    background-size: cover;
    background-position: center;
  }

  @media (max-width: 820px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-image {
      order: -1;
    }
  }

  /* ====================================
     SERVICES
  ==================================== */
  .services {
    padding: 6rem var(--site-gutter);
  }

  .services-inner {
    max-width: var(--site-max);
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 4rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
    margin-bottom: 3rem;
  }

  .service h4 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .service p {
    font-size: 0.9rem;
    color: var(--color-mid);
    line-height: 1.7;
    font-weight: 300;
  }

  .services-cta {
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ====================================
     CONTACT CTA
  ==================================== */
  .cta {
    background: var(--color-black);
    padding: 7rem var(--site-gutter);
    text-align: center;
    color: var(--color-white);
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .cta p {
    opacity: 0.6;
    margin-bottom: 2.75rem;
    line-height: 1.7;
    font-size: 1rem;
    font-weight: 300;
  }
</style>
