---
import Layout from '../layouts/Layout.astro';

const featureSections = [
  {
    title: 'Custom build.',
    image: '/pencil-design-site/images/home-hero-custom-build.jpg',
    align: 'right',
  },
  {
    title: 'Tailor made.',
    image: '/pencil-design-site/images/home-hero-tailor-made.jpg',
    align: 'left',
    href: '/pencil-design-site/projects',
    linkLabel: 'View projects',
  },
  {
    title: 'Bespoke.',
    image: '/pencil-design-site/images/home-hero-bespoke.jpg',
    align: 'right',
  },
  {
    title: 'Unique.',
    image: '/pencil-design-site/images/home-hero-unique.jpg',
    align: 'left',
  },
];
---

<Layout title="Pencil Design | Bespoke Joinery in South East London" transparentHeader={true}>

  <!-- =====================
       HERO
  ====================== -->
  <section class="hero">
    <div class="hero-bg"></div>

    <div class="hero-content">
      <h1>Not your average<br />workshop.</h1>
      <div class="hero-actions">
        <a href="/pencil-design-site/services" class="btn-pill">Our Services</a>
      </div>
    </div>
  </section>

  <section class="feature-stack">
    {featureSections.map((section) => (
      <section
        class:list={['feature-panel', `feature-panel--${section.align}`]}
        style={`background-image: url('${section.image}')`}
      >
        <div class="feature-panel__overlay"></div>
        <div class="feature-panel__content">
          <h2>{section.title}</h2>
          {section.href && (
            <a href={section.href} class="btn-pill">
              {section.linkLabel}
            </a>
          )}
        </div>
      </section>
    ))}
  </section>

</Layout>

<style>
  /* ====================================
     HERO
  ==================================== */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--site-gutter) 5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/pencil-design-site/images/home-hero-main.jpg');
    background-size: cover;
    background-position: center;
  }

  /* Subtle overlay — keep even with a real photo so text stays legible */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.2) 60%,
      rgba(0, 0, 0, 0.05) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    max-width: 1000px;
  }

  .hero-content h1 {
    /* Large, light — matching the reference's airy, confident style */
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 9vw, 8.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Pill buttons — matching the rounded outline style in the reference */
  .btn-pill {
    display: inline-block;
    padding: 0.8rem 1.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    font-weight: 400;
    text-decoration: none;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.75);
    color: var(--color-white);
    background: transparent;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-pill:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--color-white);
  }

  .btn-pill--ghost {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .btn-pill--ghost:hover {
    border-color: rgba(255, 255, 255, 0.75);
  }

  .feature-stack {
    background: var(--color-black);
  }

  .feature-panel {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--site-gutter) 4.5rem;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .feature-panel__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.58) 0%,
      rgba(0, 0, 0, 0.18) 58%,
      rgba(0, 0, 0, 0.08) 100%
    );
  }

  .feature-panel__content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: var(--color-white);
  }

  .feature-panel__content .btn-pill {
    align-self: flex-start;
    width: auto;
    padding: 0.6rem 1.2rem;
    font-size: 0.78rem;
  }

  .feature-panel--right .feature-panel__content {
    align-items: flex-end;
    text-align: right;
  }

  .feature-panel--right .feature-panel__content .btn-pill {
    align-self: flex-end;
  }

  .feature-panel__content h2 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 12vw, 10rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    max-width: 8ch;
  }

  @media (max-width: 700px) {
    .hero,
    .feature-panel {
      min-height: 72svh;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-actions .btn-pill {
      width: 100%;
      text-align: center;
    }

    .feature-panel {
      padding-bottom: 3rem;
    }

    .feature-panel--right .feature-panel__content {
      align-items: flex-start;
      text-align: left;
    }

    .feature-panel__content h2 {
      max-width: none;
    }
  }
</style>
