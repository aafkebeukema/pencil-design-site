---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/with-base';

const baseUrl = import.meta.env.BASE_URL;
const heroImage = `${baseUrl}images/home-hero-main.jpg`;

const featureSections = [
  {
    title: 'Design centric.',
    image: `${baseUrl}images/home-hero-design-centric.jpg`,
    align: 'right',
    body: 'During our design sessions, we bring together a wide range of material samples so you can see and feel the options for yourself. This hands-on approach makes it easier to make confident decisions and gives a clearer sense of the finished result.',
  },
  {
    title: 'Tailor made.',
    image: `${baseUrl}images/home-hero-tailor-made.jpg`,
    align: 'left',
    body: 'Our roots are in design, shaped by a simple belief: great ideas deserve better delivery. That is why we put so much emphasis on the design stage, developing projects with care so they can be built properly, realistically, and with integrity. By balancing design ambition with practical knowledge of materials, suppliers, and cost, we create projects that are distinctive, achievable, and tailored to your budget.',
    href: `${baseUrl}projects`,
    linkLabel: 'View projects',
  },
  {
    title: 'Bespoke.',
    image: `${baseUrl}images/home-hero-bespoke.jpg`,
    align: 'right',
  },
  {
    title: 'Unique.',
    image: `${baseUrl}images/home-hero-unique.jpg`,
    align: 'left',
  },
];
---

<Layout title="Pencil Design | Bespoke Joinery in South East London" transparentHeader={true}>

  <!-- =====================
       HERO
  ====================== -->
  <section class="hero">
    <div class="hero-bg" style={`background-image: url('${heroImage}')`}></div>

    <div class="hero-content">
      <h1>Not your average<br />construction company.</h1>
      <div class="hero-copy">
        <p>
          Pencil Design is a design-led construction and renovation company with a strong foundation in architecture, joinery and design. We build meticulously crafted spaces for homeowners and businesses. From home renovations and new-build projects to bathrooms, kitchens, wardrobes, built-in shelving, cabinetry, and one-off pieces, we design, make, and build work that is tailored to the space, built properly, and made to last.
        </p>
      </div>
      <div class="hero-actions">
        <a href={withBase('/services')} class="btn-pill">Our Services</a>
      </div>
    </div>
  </section>

  <section class="feature-stack">
    {featureSections.map((section) => (
      <section
        class:list={['feature-panel', `feature-panel--${section.align}`]}
        style={`background-image: url('${section.image}')`}
      >
        <div class="feature-panel__overlay"></div>
        <div class="feature-panel__content">
          <h2>{section.title}</h2>
          {section.body && <p class="feature-panel__copy">{section.body}</p>}
          {section.href && (
            <a href={section.href} class="btn-pill">
              {section.linkLabel}
            </a>
          )}
        </div>
      </section>
    ))}
  </section>

</Layout>

<style>
  /* ====================================
     HERO
  ==================================== */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-h) + 2.5rem) var(--content-rail) 5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  /* Subtle overlay — keep even with a real photo so text stays legible */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.2) 60%,
      rgba(0, 0, 0, 0.05) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    max-width: min(1400px, calc(100vw - (var(--site-gutter) * 2)));
  }

  .hero-content h1 {
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 7vw, 7rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 2.5rem;
  }

  .hero-copy {
    max-width: 42rem;
    display: grid;
    gap: 0.95rem;
    font-size: clamp(1rem, 1.35vw, 1.2rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 2.5rem;
  }

  .hero-copy p {
    max-width: 40rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Pill buttons — matching the rounded outline style in the reference */
  .btn-pill {
    display: inline-block;
    padding: 0.8rem 1.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    font-weight: 400;
    text-decoration: none;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.75);
    color: var(--color-white);
    background: transparent;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-pill:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--color-white);
  }

  .feature-stack {
    background: var(--color-black);
  }

  .feature-panel {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--content-rail) 4.5rem;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .feature-panel__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.58) 0%,
      rgba(0, 0, 0, 0.18) 58%,
      rgba(0, 0, 0, 0.08) 100%
    );
  }

  .feature-panel__content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: var(--color-white);
  }

  .feature-panel__content .btn-pill {
    align-self: flex-start;
    width: auto;
    padding: 0.6rem 1.2rem;
    font-size: 0.78rem;
  }

  .feature-panel--right .feature-panel__content {
    align-items: flex-end;
    text-align: right;
  }

  .feature-panel--right .feature-panel__content .btn-pill {
    align-self: flex-end;
  }

  .feature-panel__content h2 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 12vw, 10rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    max-width: 8ch;
  }

  .feature-panel__copy {
    max-width: 42rem;
    font-size: clamp(1rem, 1.35vw, 1.2rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }

  @media (max-width: 700px) {
    .hero,
    .feature-panel {
      min-height: 72svh;
    }

    .hero {
      padding-top: calc(var(--header-h) + 1.75rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-actions .btn-pill {
      width: 100%;
      text-align: center;
    }

    .feature-panel {
      padding-bottom: 3rem;
    }

    .feature-panel--right .feature-panel__content {
      align-items: flex-start;
      text-align: left;
    }

    .feature-panel__content h2 {
      max-width: none;
    }
  }
</style>
