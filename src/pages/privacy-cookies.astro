---
import Layout from '../layouts/Layout.astro';
import { buildClearedConsentCookie } from '../lib/analytics-consent';

const baseUrl = import.meta.env.BASE_URL;
---

<Layout
  title="Privacy & Cookies | Pencil Design"
  description="Privacy and cookies information for Pencil Design, including how Google Analytics is used."
>
  <div class="page-header">
    <p class="page-label">Privacy</p>
    <h1>Privacy &amp; Cookies</h1>
  </div>

  <section class="content">
    <div class="content-inner">
      <div class="policy-card">
        <h2>What we collect</h2>
        <p>
          If you contact us directly, we may receive the details you choose to send, such as your name, email address,
          phone number, and project information.
        </p>
      </div>

      <div class="policy-card">
        <h2>Analytics</h2>
        <p>
          We use Google Analytics 4 to understand how visitors use the site, such as which pages are viewed and how
          people move through the website. We only load Google Analytics after you accept analytics cookies.
        </p>
        <p>
          Google may process information such as approximate location, device information, browser information, and
          page interactions. For more information, please see Google&apos;s own privacy documentation.
        </p>
      </div>

      <div class="policy-card">
        <h2>Cookies we use</h2>
        <p>
          We use one necessary cookie to remember your analytics choice. If you accept analytics cookies, Google
          Analytics may also set its own measurement cookies.
        </p>
      </div>

      <div class="policy-card">
        <h2>Change your choice</h2>
        <p>
          You can clear your saved analytics preference below. Once cleared, the cookie banner will appear again and you
          can choose whether to accept or reject analytics cookies.
        </p>
        <button type="button" class="reset-button" data-reset-analytics-consent>
          Reset cookie choice
        </button>
      </div>
    </div>
  </section>

  <script define:vars={{ baseUrl, clearedConsentCookie: buildClearedConsentCookie(baseUrl) }}>
    const resetButton = document.querySelector('[data-reset-analytics-consent]');

    resetButton?.addEventListener('click', () => {
      document.cookie = clearedConsentCookie;
      window.location.reload();
    });
  </script>
</Layout>

<style>
  .page-header {
    padding: calc(var(--header-h) + 3rem) var(--site-gutter) 3rem;
    text-align: center;
  }

  .page-label {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    margin-bottom: 1rem;
  }

  .page-header h1 {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: clamp(2rem, 9vw, 7rem);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  .content {
    padding: 0 var(--site-gutter) 5rem;
  }

  .content-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    gap: 1.25rem;
  }

  .policy-card {
    border: 1px solid var(--color-border);
    padding: 1.6rem;
    background: var(--color-off-white);
  }

  .policy-card h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 400;
    margin-bottom: 0.8rem;
  }

  .policy-card p {
    font-size: 0.96rem;
    line-height: 1.8;
    color: #4f4f4f;
    margin-bottom: 0.9rem;
  }

  .policy-card p:last-child {
    margin-bottom: 0;
  }

  .reset-button {
    appearance: none;
    border: 1px solid var(--color-black);
    background: transparent;
    color: var(--color-black);
    padding: 0.8rem 1.15rem;
    border-radius: 999px;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
</style>
