import CategoryPage from '../components/CategoryPage.astro';

const projects = [
  {
    title: 'Peckham Kitchen',
    description: 'Bespoke handleless kitchen with integrated appliances and a solid oak island.',
    bg: 'linear-gradient(155deg, #7a5c2e 0%, #a07840 100%)',
  },
  {
    title: 'Dulwich Master Bedroom',
    description: 'Floor-to-ceiling fitted wardrobes with soft-close drawers and internal lighting.',
    bg: 'linear-gradient(155deg, #2c3552 0%, #3f4f73 100%)',
  },
  {
    title: 'Herne Hill Alcoves',
    description: 'Built-in shelving and a media unit either side of the chimney breast.',
    bg: 'linear-gradient(155deg, #2d4a38 0%, #4a6e52 100%)',
  },
  {
    title: 'Brixton Living Room',
    description: 'Alcove shelving with hidden storage drawers below — painted in F&B Mole\'s Breath.',
    bg: 'linear-gradient(155deg, #3a2515 0%, #5c3e20 100%)',
  },
  {
    title: 'Forest Hill Kitchen',
    description: 'Shaker-style kitchen with hand-painted cabinetry and open oak shelving.',
    bg: 'linear-gradient(155deg, #4a3820 0%, #6e5530 100%)',
  },
  {
    title: 'Crystal Palace Home Office',
    description: 'Fitted desk, bookshelves, and storage for a dedicated work-from-home room.',
    bg: 'linear-gradient(155deg, #1c2c3a 0%, #2e4558 100%)',
  },
];
---

<Layout
  title="Residential Projects | Sam's Joinery"
  description="Bespoke residential joinery in South East London — kitchens, wardrobes, alcove shelving, and fitted furniture."
>
  <CategoryPage
    category="Residential"
    headline="Built for the way you live."
    intro="We work with homeowners across South East London to create fitted furniture that genuinely improves how a home works and feels. Kitchens, wardrobes, living room joinery, home offices — everything is designed and made to fit your space and your life. No off-the-shelf solutions."
    heroBg="linear-gradient(160deg, #1e1408 0%, #2e1e0a 55%, #180f05 100%)"
    projects={projects}
  />
</Layout>
