---
import Layout from '../layouts/Layout.astro';
import CategoryPage from '../components/CategoryPage.astro';

const projects = [
  {
    title: 'Bermondsey Creative Studio',
    description: 'Bespoke workbenches, pin boards, and storage for a ten-person creative agency.',
    bg: 'linear-gradient(155deg, #1a1a1a 0%, #303030 100%)',
  },
  {
    title: 'Peckham Tech Office',
    description: 'Fitted joinery throughout — reception desk, meeting room shelving, and breakout seating.',
    bg: 'linear-gradient(155deg, #1c2535 0%, #2e3f58 100%)',
  },
  {
    title: 'Herne Hill Photography Studio',
    description: 'Prop storage, a custom backdrop rail system, and a built-in kitchenette.',
    bg: 'linear-gradient(155deg, #251e15 0%, #3c3020 100%)',
  },
  {
    title: 'Camberwell Architect\'s Practice',
    description: 'Floor-to-ceiling plan storage, a sample library wall, and bespoke partner desks.',
    bg: 'linear-gradient(155deg, #1e2428 0%, #303c44 100%)',
  },
  {
    title: 'Forest Hill Co-working Space',
    description: 'Fitted desking, lockers, and acoustic booth joinery for a new co-working venue.',
    bg: 'linear-gradient(155deg, #1c1c1c 0%, #2e2e2e 100%)',
  },
  {
    title: 'Borough Market Office',
    description: 'Reception counter, breakout shelving, and custom credenzas throughout the open plan office.',
    bg: 'linear-gradient(155deg, #1e2830 0%, #2e3e4a 100%)',
  },
];
---

<Layout
  title="Workspace Projects | Sam's Joinery"
  description="Bespoke workspace joinery in London — offices, studios, co-working spaces, and commercial interiors."
>
  <CategoryPage
    category="Workspace"
    headline="Places worth coming to work in."
    intro="Good workplace joinery does more than just look the part — it makes a space more functional, more focused, and more pleasant to be in every day. We work with businesses, architects, and interior designers to deliver bespoke office and studio joinery across London."
    heroBg="linear-gradient(160deg, #101520 0%, #182030 55%, #0c1018 100%)"
    projects={projects}
  />
</Layout>
