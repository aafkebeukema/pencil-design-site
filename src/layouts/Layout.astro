---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  transparentHeader?: boolean;
}

const {
  title = "Pencil Design",
  description = "Bespoke joinery and design in South East London.",
  transparentHeader = false,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const googleAnalyticsId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const canonicalUrl = Astro.url;
const socialImageUrl = new URL(`${baseUrl}images/home-hero-main.jpg`, Astro.site ?? Astro.url);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': `${new URL(baseUrl, Astro.site ?? Astro.url)}#business`,
  name: 'Pencil Design',
  url: new URL(baseUrl, Astro.site ?? Astro.url).toString(),
  image: socialImageUrl.toString(),
  description,
  telephone: '+44 20 8016 4163',
  email: 'contact@pencil-design.co.uk',
  areaServed: 'South East London',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'South East London',
    addressCountry: 'GB',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon-pencil.svg`} />
    <link rel="icon" href={`${baseUrl}favicon-pencil.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@300;400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pencil Design" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header transparent={transparentHeader} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <CookieBanner baseUrl={baseUrl} measurementId={googleAnalyticsId} />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-black: #0f0f0f;
    --color-white: #ffffff;
    --color-off-white: #f7f5f2;
    --color-mid: #6b6b6b;
    --color-border: rgba(0, 0, 0, 0.1);
    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --site-max: 1400px;
    --site-gutter: clamp(1.25rem, 4vw, 3.5rem);
    --content-rail: max(var(--site-gutter), calc((100vw - var(--site-max)) / 2 + var(--site-gutter)));
    --header-h: 72px;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    color: var(--color-black);
    background: var(--color-white);
    line-height: 1.6;
    overflow-x: hidden;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  a {
    color: inherit;
  }

  /* ── Focus styles ── */
  :focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 3px;
  }

  /* ── Skip link ── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-black);
    color: var(--color-white);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: top 0.15s;
  }

  .skip-link:focus {
    top: 1rem;
  }
</style>
